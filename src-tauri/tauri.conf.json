{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Draftboard",
  "version": "0.4.1",
  "identifier": "com.draftboard.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Draftboard — LoL Draft Advisor",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      },
      {
        "label": "overlay",
        "title": "Draftboard Overlay",
        "url": "index.html?overlay=1",
        "width": 320,
        "height": 340,
        "x": 30,
        "y": 80,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline' https://rsms.me",
        "font-src": "'self' https://rsms.me data:",
        "img-src": "'self' data: blob: https://ddragon.leagueoflegends.com https://raw.communitydragon.org https://*.op.gg",
        "connect-src": "'self' ipc: http://ipc.localhost https://*.api.riotgames.com https://*.workers.dev https://ddragon.leagueoflegends.com https://raw.communitydragon.org https://api.anthropic.com https://api.groq.com https://generativelanguage.googleapis.com https://rsms.me https://lol.fandom.com https://mcp-api.op.gg https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://*.ingest.de.sentry.io"
      },
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline' https://rsms.me",
        "font-src": "'self' https://rsms.me data:",
        "img-src": "'self' data: blob: https://ddragon.leagueoflegends.com https://raw.communitydragon.org https://*.op.gg",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420 https://*.api.riotgames.com https://*.workers.dev https://ddragon.leagueoflegends.com https://raw.communitydragon.org https://api.anthropic.com https://api.groq.com https://generativelanguage.googleapis.com https://rsms.me https://lol.fandom.com https://mcp-api.op.gg https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://*.ingest.de.sentry.io"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Pro-level LoL draft advisor + AI coach",
    "longDescription": "Premium League of Legends draft advisor with AI coaching, mastery-weighted suggestions, multi-region pro meta, live game inspection, and 7-day improvement plans. 100% local data, free to use.",
    "copyright": "© 2026 Draftboard",
    "publisher": "Draftboard",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["es-ES", "en-US"]
      },
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true,
        "languages": ["English", "Spanish"]
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://draftboard-riot-proxy.rafael-lopez-serrano-99.workers.dev/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1NjFCQUVENkI0ODRENDEKUldSQlRVaHI3YnBoZGRESHl0VUhkUzdGTklGU0RUUWluYTFVNzdvZmdSdVFGQjZzN0EzWXFMUE0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
