{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Draftboard",
  "version": "0.3.0",
  "identifier": "com.draftboard.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Draftboard — LoL Draft Advisor",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Pro-level LoL draft advisor + AI coach",
    "longDescription": "Premium League of Legends draft advisor with AI coaching, mastery-weighted suggestions, multi-region pro meta, live game inspection, and 7-day improvement plans. 100% local data, free to use.",
    "copyright": "© 2026 Draftboard",
    "publisher": "Draftboard",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["es-ES", "en-US"]
      },
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true,
        "languages": ["English", "Spanish"]
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://draftboard-riot-proxy.rafael-lopez-serrano-99.workers.dev/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1NjFCQUVENkI0ODRENDEKUldSQlRVaHI3YnBoZGRESHl0VUhkUzdGTklGU0RUUWluYTFVNzdvZmdSdVFGQjZzN0EzWXFMUE0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
