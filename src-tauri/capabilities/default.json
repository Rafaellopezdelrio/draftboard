{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.api.riotgames.com/*" },
        { "url": "https://*.workers.dev/*" },
        { "url": "https://ddragon.leagueoflegends.com/*" },
        { "url": "https://raw.communitydragon.org/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.groq.com/*" },
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "https://rsms.me/*" },
        { "url": "https://lol.fandom.com/*" },
        { "url": "https://mcp-api.op.gg/*" },
        { "url": "https://*.ingest.sentry.io/*" },
        { "url": "https://*.ingest.us.sentry.io/*" },
        { "url": "https://*.ingest.de.sentry.io/*" }
      ]
    }
  ]
}
