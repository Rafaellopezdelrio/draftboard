{
  "name": "draftboard",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run typecheck && npm run test && npm run test:e2e",
    "test:flaky": "node -e \"for(let i=1;i<=10;i++){require('child_process').execSync('npx vitest run',{stdio:'inherit'})}\"",
    "bundle-check": "node scripts/bundle-check.mjs",
    "verify:data": "node scripts/verify-data.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "rust:check": "cd src-tauri && cargo clippy --all-targets -- -D warnings && cargo fmt --check",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:fix": "cd src-tauri && cargo clippy --fix --allow-dirty --allow-staged --all-targets",
    "check:all": "npm run typecheck && npm run test && npm run rust:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "@tanstack/react-query": "^5.100.9",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "i18next": "^25.10.10",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.6.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.4",
    "vitest": "^2.1.9",
    "vitest-axe": "^0.1.0"
  }
}
