#!/usr/bin/env sh
# Pre-commit guard — block bad commits at the source.
#
# Runs the two cheapest, highest-signal checks: full project typecheck
# (~3-5s) + ESLint react-hooks rules (~2-3s). The lint gate catches
# rules-of-hooks violations (conditional hooks = latent "rendered more
# hooks" crashes) and stale-closure deps BEFORE they ship. vitest +
# rust:check are NOT run here — too slow for a commit gate (~40s combined).
# CI catches those via .github/workflows/ci.yml.
#
# Skip in emergencies: git commit --no-verify (then fix in follow-up).
# But anything you skip must be fixed before push — CI will block PR.

npm run typecheck
npm run lint
